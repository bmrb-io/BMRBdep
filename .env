# Pproduction
ENVIRONMENT=production
# Development
#ENVIRONMENT=development

# Path to the backend configuration file on the host. If unset, defaults to
# /projects/BMRB/public/BMRBdep/BackEnd/bmrbdep/configuration_${ENVIRONMENT}.json
#CONFIG_FILE=/projects/BMRB/public/BMRBdep/BackEnd/bmrbdep/configuration_production.json

# Host directory holding depositions, mounted at /opt/wsgi/depositions.
# If unset, defaults to /projects/BMRB/depositions/bmrbdep
#DEPOSITIONS_DIR=/projects/BMRB/depositions/bmrbdep

# UID and GID the container runs as. Defaults to 17473:10144 (bmrbsvc).
#UID=17473
#GID=10144
